PORT=3000
APP_URL=http://127.0.0.1:3000

# Token/session signing secret used by the local SaaS authentication flow.
SESSION_SECRET=troque-este-segredo-em-producao

# Local default for development. The current workspace runs with SQLite.
DATABASE_URL="file:./dev.db"

# Production target requested by the technical test.
# Example:
# DATABASE_URL="postgresql://usuario:senha@localhost:5432/erp_contratos_obras?schema=public"

# Optional AI integration used by the existing project.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
